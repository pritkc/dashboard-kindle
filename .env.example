# Loopback-only (default for local browser testing):
# DASHBOARD_KINDLE_HOST=127.0.0.1
# DASHBOARD_KINDLE_ADMIN_TOKEN=dev-admin-token
# DASHBOARD_KINDLE_MASTER_KEY=dev-only-change-me

# LAN / Kindle access (listen on all interfaces):
DASHBOARD_KINDLE_HOST=0.0.0.0
DASHBOARD_KINDLE_PORT=8787
DASHBOARD_KINDLE_DATA_DIR=./data
DASHBOARD_KINDLE_ADMIN_TOKEN=replace-with-a-strong-token
DASHBOARD_KINDLE_MASTER_KEY=replace-with-a-long-random-value
DASHBOARD_KINDLE_BACKUP_INTERVAL_SECONDS=86400
